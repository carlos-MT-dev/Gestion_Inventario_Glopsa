  <!-- ═══════════════════════════════════
           CONTENIDO PRINCIPAL
      ═══════════════════════════════════ -->
      <main class="content">
        <h1>Gestión de Campos</h1>

        <p class="subtitle">
          Administración de categorías de los campos del sistema
        </p>

        <!-- ──────────────────────────────
             TABLA DE CAMPOS
        ────────────────────────────── -->
        <section class="card card-tabla">
          <h2>Listado de campos registrados</h2>

          <div class="tabla-container">
            <table class="Lista_campos">
              <thead class="cabecera_tabla_lista_campos">
                <tr>
                  <th>IdCampo</th>
                  <th>Nombre del campo</th>
                  <th>Categoría</th>
                  <th>Estado</th>
                  <th>Editar</th>
                  <th>Eliminar</th>
                </tr>
              </thead>

              <tbody
                class="tbody_tabla_lista_campos"
                id="tbody_tabla_lista_campos"
              ></tbody>
            </table>
          </div>

          <div class="footer-table">
            <i class="fas fa-cube" id="recuento_res"></i>

            Mostrando
            <span id="recuento_res_num"></span>
            <span id="nombre_campo_listado"></span>
          </div>
        </section>

        <!-- version nuva -->

        <form
          class="card form-card"
          id="form_nuevos_campos"
          method="POST"
          action="/registrar_nuevos_datos"
        >
          <h2>Registro de nuevos campos</h2>
          <p>Completa los datos para agregar o modificar un campo</p>

          <div class="form-row">
            <div class="input-group">
              <label for="id_campo">id campo</label>
              <input 
                type="text"
                id="txt_id_campos" 
                name="id_campo"
            
                 />
            </div>

            <div class="input-group">
              <label for="nombre_campo">Nombre campo</label>
              <input
                type="text"
                id="txt_agregar_nombre_campos"
                name="nombre_campo"
              />
            </div>

            <div class="input-group">
              <label for="tabla">Tabla</label>
              <select
                name="tabla"
                id="cbb_agregar_tabla_campos"
                class="cbb_agregar_nuevos_campos cbb"
              >
                <option value="SELECCIONAR">SELECCIONAR</option>
                <option value="item">OBJETOS</option>
                <option value="modelo">MODELOS</option>
                <option value="marca">MARCAS</option>
              </select>
            </div>

            <div class="input-group">
              <label for="categoria">Categoria</label>
              <select
                name="categoria"
                id="cbb_agregar_categoria_campos"
                class="cbb_agregar_nuevos_campos cbb"
              ></select>
            </div>

            <div class="input-group">
              <label for="estado">Estado</label>
              <select
                name="estado"
                id="cbb_agregar_estado_campos"
                class="cbb_agregar_nuevos_campos cbb"
              ></select>
            </div>
          </div>

          <div class="input-group">
            <label for="descripcion">Descripcion</label>
            <textarea
              rows="4"
              id="txt_descripcion_campos"
              name="descripcion"
            ></textarea>
          </div>

          <div class="action-buttons">
            <button type="button" class="btn-primary" id="btn_agregar_campos">
              <i class="fas fa-plus"></i>
              Agregar
            </button>

            <button type="button" class="btn-primary" id="btn_actualizar_campo">
              <i class="fas fa-rotate"></i>
              Actualizar
            </button>

            <button type="button" class="btn-primary">
              <i class="fas fa-trash"></i>
              Eliminar
            </button>
          </div>
        </form>
      </main>