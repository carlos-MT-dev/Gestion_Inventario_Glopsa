<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GLOSAP - Inventario</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Sora:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Select2 CSS -->
    <link
      href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css"
      rel="stylesheet"
    />

    <!-- CSS Rediseñado -->
    <link
      rel="stylesheet"
      href="/GESTION DE INVENTARIO/Style/registro-css.css"
    />
  </head>

  <body>
    <!-- ═══════════════════════════════════
         NAVBAR
    ═══════════════════════════════════ -->
    <div id="navbar-container">
      <nav class="navbar">
        <div class="nav-left">
          <img
            src="/GESTION DE INVENTARIO/asset/BLANCO.png"
            alt="Logo GLOSAP"
            class="nav-logo"
          />
          <span class="nav-title">Gestión Corporativa</span>
        </div>

        <ul class="nav-menu">
          <li>
            <a href="../../html_reenvio_pagina_no_encontrada.html">Dashboard</a>
          </li>
          <li class="active"><a href="#">Inventario</a></li>
          <li>
            <a href="../../MOVIMIENTO_INVENTARIO/view/prestamo.html"
              >Préstamos</a
            >
          </li>
          <li>
            <a href="../../html_reenvio_pagina_no_encontrada.html">Reportes</a>
          </li>
          <li>
            <a href="../../html_reenvio_pagina_no_encontrada.html">Log Out</a>
          </li>
        </ul>
      </nav>
    </div>

    <!-- ═══════════════════════════════════
         CONTENEDOR PRINCIPAL
    ═══════════════════════════════════ -->
    <div class="container">
      <!-- HEADER -->
      <div class="header">
        <h1><span class="red">Registrar</span> Artículo</h1>
      </div>

      <!-- ═══════════════════════════════════
           FORMULARIO
      ═══════════════════════════════════ -->
      <form method="POST" id="form-registro" class="form">
        <!-- FILA 1: Identificación -->
        <div class="row">
          <div class="input-box">
            <label for="Codigo">Código</label>
            <input
              id="Codigo"
              name="Codigo"
              type="text"
              placeholder="Auto-generado"
            />
          </div>

          <div class="input-box">
            <label for="ID_area">Área</label>
            <select id="ID_area" class="cbb-form" name="ID_area"></select>
          </div>

          <div class="input-box">
            <label for="ID_categoria">Categoría</label>
            <select
              id="ID_categoria"
              class="cbb-form"
              name="ID_categoria"
            ></select>
          </div>

          <div class="input-box">
            <label for="ID_objeto">Objeto</label>
            <select id="ID_objeto" class="cbb-form" name="ID_objeto"></select>
          </div>

          <div class="input-box">
            <label for="ID_marca">Marca</label>
            <select id="ID_marca" class="cbb-form" name="ID_marca"></select>
          </div>
        </div>

        <!-- FILA 2: Detalles del artículo -->
        <div class="row">
          <div class="input-box">
            <label for="ID_modelo">Modelo</label>
            <select id="ID_modelo" class="cbb-form" name="ID_modelo"></select>
          </div>

          <div class="input-box">
            <label for="ID_medida">Unidad de Medida</label>
            <select id="ID_medida" class="cbb-form" name="ID_medida"></select>
          </div>

          <div class="input-box">
            <label for="Unidad_txt">Unidades a registrar</label>
            <input
              type="text"
              id="Unidad_txt"
              name="Unidad_txt"
              placeholder="0"
            />
          </div>

          <div class="input-box">
            <label for="ID_sede">Sede</label>
            <select id="ID_sede" class="cbb-form" name="ID_sede"></select>
          </div>

          <div class="input-box">
            <label for="ID_Estado">Estado</label>
            <select id="ID_Estado" class="cbb-form" name="ID_Estado"></select>
          </div>
        </div>

        <!-- FILA 3: Condición y fecha -->
        <div class="row">
          <div class="input-box">
            <label for="ID_Disponibilidad">Disponibilidad</label>
            <select
              id="ID_Disponibilidad"
              class="cbb-form"
              name="ID_Disponibilidad"
            ></select>
          </div>

          <div class="input-box">
            <label for="ID_Condicion">Condición</label>
            <select
              id="ID_Condicion"
              name="ID_Condicion"
              class="cbb-form"
            ></select>
          </div>

          <div class="input-box">
            <label for="ID_seccion">Sección</label>
            <select id="ID_seccion" class="cbb-form" name="ID_seccion"></select>
          </div>

          <div class="input-box">
            <label for="Fecha_Compra">Fecha de compra</label>
            <input
              type="date"
              id="Fecha_Compra"
              name="Fecha_Compra"
              class="cbb-form"
            />
          </div>

          <div class="input-box large">
            <label for="Descripcion">Descripción</label>
            <input
              id="Descripcion"
              name="Descripcion"
              type="text"
              placeholder="Observaciones del artículo..."
            />
          </div>
        </div>

        <!-- FILA EXTRA (dinámica desde JS) -->
        <div class="row"></div>

        <!-- BOTONES DE ACCIÓN -->
        <div class="buttons">
          <button type="button" id="btn-buscar" class="btn search">
            🔍 Buscar
          </button>

          <button type="button" id="btn-reset" class="btn errase">
            🗑 Borrar campos
          </button>

          <button type="button" id="btn-actualizar" class="btn update">
            🔄 Actualizar
          </button>

          <button type="button" id="btn-eliminar" class="btn remove">
            ❌ Eliminar
          </button>

          <button type="button" id="btn-registrar" class="btn register">
            ✔ Registrar
          </button>

          <button
            type="button"
            id="btn_agregar_nuevos_campos"
            class="btn agregar-campos"
          >
            ⚙ Agregar campos
          </button>
        </div>
      </form>

      <!-- DIVISOR -->
      <hr class="divider" />

      <!-- ═══════════════════════════════════
           LISTA DE REGISTROS
      ═══════════════════════════════════ -->
      <h2 class="list-title">
        <span class="red">Lista</span> de Registro
        <span class="gray">| Inventario General</span>
      </h2>

      <table class="table">
        <thead>
          <tr class="cabeceras">
            <th>Código</th>
            <th>Área</th>
            <th>Sede</th>
            <th>Objeto</th>
            <th>Categoría</th>
            <th>Marca</th>
            <th>Modelo</th>
            <th>Estado</th>
            <th>Registro</th>
            <th>Disponib.</th>
            <th>Condición</th>
            <th>Sección</th>
            <th>Fecha Compra</th>
            <th>Selec.</th>
            <th>Mover</th>
            <th>Cód. Bar</th>
          </tr>
        </thead>
        <tbody id="tbody-objetos"></tbody>
      </table>
    </div>
    <!-- /container -->

    <!-- ═══════════════════════════════════
         SCRIPTS (orden original preservado)
    ═══════════════════════════════════ -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode/dist/JsBarcode.all.min.js"></script>


    <script src="/GESTION DE INVENTARIO/controler/registro_inventario/api.js"></script>
    <script type="module" src="/GESTION DE INVENTARIO/controler/registro_inventario/eventos.js"></script>

    <script src="/GESTION DE INVENTARIO/controler/agregar_nuevos_campos/mostrar_ventana_agregar_nuevoscampos.js"></script>

  
  </body>
</html>
